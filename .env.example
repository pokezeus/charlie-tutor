# Charlie Tutor Environment Variables
# Copy this file to .env.local and fill in the values

# Railway Project Context
RAILWAY_PROJECT_ID="charlie-tutor"
RAILWAY_ENVIRONMENT_ID="production"

# AI Agent Network Configuration
# These allow Charlie-tutor to communicate with the agent cluster
AGENT_NETWORK_URL="http://openclaw-zeus:8080" 
AGENT_API_KEY="your_secure_agent_api_key_here"

# Application Settings
NEXT_PUBLIC_APP_NAME="Charlie Tutor"
NEXT_PUBLIC_LEAD_AGENT="apollo"
NEXT_PUBLIC_DEV_AGENT="athena"

# Database (if needed later)
# DATABASE_URL=""
